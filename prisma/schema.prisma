
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EstadoExpedienteGlobal {
  BORRADOR
  RECIBIDO
  DOCUMENTAL
  INCOMPATIBILIDADES
  TECNICA
  LEGAL
  KML_SIG
  OBSERVADO
  CORRECCION
  INFORME
  CONTROL
  APROBADO
  INGRESADO
  CERRADO
  RECHAZADO
  VENCIDO
}

enum EstadoEtapa {
  PENDIENTE
  HABILITADA
  EN_PROGRESO
  OBSERVADA
  BLOQUEADA
  CERRADA
  REABIERTA
  RECHAZADA
  VENCIDA
}

enum TipoEtapa {
  RECEPCION
  CHECKLIST
  INCOMPATIBILIDADES
  REVISION_TECNICA
  REVISION_LEGAL
  KML_SIG
  INFORME_TECNICO
  CONTROL_FINAL
  INGRESO_SAG
  CIERRE
}

enum SeveridadAlerta {
  INFORMATIVA
  ADVERTENCIA
  CRITICA
}

enum SeveridadNC {
  MENOR
  MAYOR
  CRITICA
}

enum ResultadoRevision {
  APROBADA
  APROBADA_CON_OBSERVACIONES
  RECHAZADA
}

enum CanalRecepcion {
  PRESENCIAL
  CORREO
  PLATAFORMA_DIGITAL
  INTERNO
}

enum PrioridadExpediente {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum OrigenAlerta {
  AUTOMATICA
  MANUAL
}

enum ScopeType {
  EXPEDIENTE
  ETAPA
  SISTEMA
}

enum EstadoRegistro {
  BORRADOR
  VIGENTE
  CERRADO
  ANULADO
}

enum EstadoAdmisibilidad {
  ADMISIBLE
  INADMISIBLE_OBSERVADA
}

enum EstadoAlerta {
  ACTIVA
  RESUELTA
  CANCELADA
}

enum EstadoNoConformidad {
  ABIERTA
  EN_PROCESO
  CERRADA
  CANCELADA
}

enum EstadoAccionCorrectiva {
  PENDIENTE
  EN_PROCESO
  CERRADA
  VENCIDA
}

enum EstadoInformeTecnico {
  BORRADOR
  VIGENTE
  CERRADO
}

enum EstadoControlFinal {
  BORRADOR
  APROBADO
  OBSERVADO
  RECHAZADO
}

enum EstadoDocumento {
  ACTIVO
  OBSERVADO
  ANULADO
}

enum EstadoVersionDocumento {
  ACTIVA
  REEMPLAZADA
  ANULADA
}

enum EstadoReportJob {
  PENDIENTE
  EN_PROCESO
  COMPLETADO
  FALLIDO
}

model Usuario {
  id                          String                        @id @default(uuid())
  email                       String                        @unique
  passwordHash                String                        @map("password_hash")
  fullName                    String                        @map("full_name")
  initials                    String?                       @map("initials")
  isActive                    Boolean                       @default(true) @map("is_active")
  lastLoginAt                 DateTime?                     @map("last_login_at")
  createdAt                   DateTime                      @default(now()) @map("created_at")
  updatedAt                   DateTime                      @updatedAt @map("updated_at")
  deletedAt                   DateTime?                     @map("deleted_at")
  createdExpedientes          Expediente[]                  @relation("ExpedienteCreatedBy")
  responsibleExpedientes      Expediente[]                  @relation("ExpedienteProfesionalResponsable")
  assignedReviewExpedientes   Expediente[]                  @relation("ExpedienteRevisorAsignado")
  userRoles                   UsuarioRol[]
  recepcionesCreadas          RecepcionExpediente[]         @relation("RecepcionCreatedBy")
  checklistResultados         ChecklistItemResultado[]      @relation("ChecklistItemResultadoUsuario")
  declaraciones               DeclaracionIncompatibilidad[] @relation("DeclaracionUsuario")
  revisionesTecnicas          RevisionTecnica[]             @relation("RevisionTecnicaRevisor")
  revisionesLegales           RevisionLegal[]               @relation("RevisionLegalRevisor")
  validacionesKml             ValidacionKml[]               @relation("ValidacionKmlRevisor")
  informesTecnicosCreados     InformeTecnico[]              @relation("InformeTecnicoCreatedBy")
  informeVersionesCreadas     InformeTecnicoVersion[]       @relation("InformeTecnicoVersionCreatedBy")
  controlesFinales            ControlFinal[]                @relation("ControlFinalAprobador")
  versionesDocumento          DocumentoVersion[]            @relation("DocumentoVersionUploadedBy")
  alertasResponsable          Alerta[]                      @relation("AlertaResponsable")
  alertasResueltas            Alerta[]                      @relation("AlertaResolvedBy")
  noConformidadesResponsable  NoConformidad[]              @relation("NoConformidadResponsable")
  accionesCorrectivas         AccionCorrectiva[]            @relation("AccionCorrectivaResponsable")
  reaperturas                 ReaperturaEtapa[]             @relation("ReaperturaUsuario")
  etapasResponsable           ExpedienteEtapa[]             @relation("ExpedienteEtapaResponsable")
  expedienteEstadosCambiados  ExpedienteHistorialEstado[]   @relation("ExpedienteHistorialEstadoChangedBy")
  etapaEstadosCambiados       ExpedienteEtapaHistorialEstado[] @relation("ExpedienteEtapaHistorialEstadoChangedBy")
  auditLogs                   AuditLog[]                    @relation("AuditLogUsuario")
  reportJobs                  ReportJob[]                   @relation("ReportJobSolicitante")

  @@map("usuarios")
}

model Rol {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  description  String?
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  userRoles    UsuarioRol[]
  rolePermisos RolPermiso[]

  @@map("roles")
}

model Permiso {
  id           String       @id @default(uuid())
  code         String       @unique
  name         String
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  rolePermisos RolPermiso[]

  @@map("permisos")
}

model UsuarioRol {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  rolId     String   @map("rol_id")
  createdAt DateTime @default(now()) @map("created_at")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, rolId])
  @@index([rolId])
  @@map("usuario_roles")
}

model RolPermiso {
  id        String   @id @default(uuid())
  rolId     String   @map("rol_id")
  permisoId String   @map("permiso_id")
  createdAt DateTime @default(now()) @map("created_at")
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso   Permiso  @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@index([permisoId])
  @@map("rol_permisos")
}

model Expediente {
  id                            String                   @id @default(uuid())
  codigoInterno                 String                   @unique @map("codigo_interno")
  estadoGlobal                  EstadoExpedienteGlobal   @map("estado_global")
  nombrePropietario             String                   @map("nombre_propietario")
  rutPropietario                String                   @map("rut_propietario")
  nombreProyecto                String?                  @map("nombre_proyecto")
  rolPredial                    String                   @map("rol_predial")
  region                        String
  provincia                     String
  comuna                        String
  superficieTotal               Decimal                  @db.Decimal(12, 2) @map("superficie_total")
  numeroLotes                   Int                      @map("numero_lotes")
  numeroPlanosRecibidos         Int?                     @map("numero_planos_recibidos")
  presenciaKml                  Boolean?                 @map("presencia_kml")
  canalRecepcion                CanalRecepcion           @map("canal_recepcion")
  prioridad                     PrioridadExpediente
  fechaRecepcion                DateTime                 @map("fecha_recepcion")
  fechaLimiteSag                DateTime?                @map("fecha_limite_sag")
  observacionesIniciales        String?                  @db.Text @map("observaciones_iniciales")
  profesionalResponsableId      String                   @map("profesional_responsable_id")
  revisorAsignadoId             String?                  @map("revisor_asignado_id")
  createdById                   String?                  @map("created_by")
  updatedById                   String?                  @map("updated_by")
  createdAt                     DateTime                 @default(now()) @map("created_at")
  updatedAt                     DateTime                 @updatedAt @map("updated_at")
  deletedAt                     DateTime?                @map("deleted_at")
  profesionalResponsable        Usuario                  @relation("ExpedienteProfesionalResponsable", fields: [profesionalResponsableId], references: [id])
  revisorAsignado               Usuario?                 @relation("ExpedienteRevisorAsignado", fields: [revisorAsignadoId], references: [id])
  createdBy                     Usuario?                 @relation("ExpedienteCreatedBy", fields: [createdById], references: [id])
  recepcion                     RecepcionExpediente?
  etapas                        ExpedienteEtapa[]
  historialEstados              ExpedienteHistorialEstado[]
  reaperturas                   ReaperturaEtapa[]
  checklists                    Checklist[]
  declaracionesIncompatibilidad DeclaracionIncompatibilidad[]
  revisionesTecnicas            RevisionTecnica[]
  revisionesLegales             RevisionLegal[]
  validacionesKml               ValidacionKml[]
  informesTecnicos              InformeTecnico[]
  controlesFinales              ControlFinal[]
  documentos                    Documento[]
  alertas                       Alerta[]
  noConformidades               NoConformidad[]
  auditLogs                     AuditLog[]

  @@index([estadoGlobal])
  @@index([profesionalResponsableId])
  @@index([revisorAsignadoId])
  @@index([fechaRecepcion])
  @@map("expedientes")
}
model ExpedienteEtapa {
  id                     String                         @id @default(uuid())
  expedienteId           String                         @map("expediente_id")
  tipoEtapa              TipoEtapa                      @map("tipo_etapa")
  estadoEtapa            EstadoEtapa                    @map("estado_etapa")
  responsableUserId      String?                        @map("responsable_user_id")
  startedAt              DateTime?                      @map("started_at")
  finishedAt             DateTime?                      @map("finished_at")
  dueAt                  DateTime?                      @map("due_at")
  createdAt              DateTime                       @default(now()) @map("created_at")
  updatedAt              DateTime                       @updatedAt @map("updated_at")
  expediente             Expediente                     @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  responsable            Usuario?                       @relation("ExpedienteEtapaResponsable", fields: [responsableUserId], references: [id])
  historialEstados       ExpedienteEtapaHistorialEstado[]
  reaperturas            ReaperturaEtapa[]
  documentos             Documento[]
  revisionesTecnicas     RevisionTecnica[]
  revisionesLegales      RevisionLegal[]
  validacionesKml        ValidacionKml[]
  informesTecnicos       InformeTecnico[]
  controlesFinales       ControlFinal[]

  @@unique([expedienteId, tipoEtapa])
  @@index([responsableUserId])
  @@map("expediente_etapas")
}

model ExpedienteHistorialEstado {
  id              String                  @id @default(uuid())
  expedienteId    String                  @map("expediente_id")
  estadoAnterior  EstadoExpedienteGlobal? @map("estado_anterior")
  estadoNuevo     EstadoExpedienteGlobal  @map("estado_nuevo")
  changedByUserId String?                 @map("changed_by_user_id")
  comentario      String?                 @db.Text
  createdAt       DateTime                @default(now()) @map("created_at")
  expediente      Expediente              @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  changedBy       Usuario?                @relation("ExpedienteHistorialEstadoChangedBy", fields: [changedByUserId], references: [id])

  @@index([expedienteId, createdAt])
  @@map("expediente_historial_estados")
}

model ExpedienteEtapaHistorialEstado {
  id               String          @id @default(uuid())
  expedienteEtapaId String         @map("expediente_etapa_id")
  estadoAnterior   EstadoEtapa?    @map("estado_anterior")
  estadoNuevo      EstadoEtapa     @map("estado_nuevo")
  changedByUserId  String?         @map("changed_by_user_id")
  comentario       String?         @db.Text
  createdAt        DateTime        @default(now()) @map("created_at")
  expedienteEtapa  ExpedienteEtapa @relation(fields: [expedienteEtapaId], references: [id], onDelete: Cascade)
  changedBy        Usuario?        @relation("ExpedienteEtapaHistorialEstadoChangedBy", fields: [changedByUserId], references: [id])

  @@index([expedienteEtapaId, createdAt])
  @@map("expediente_etapa_historial_estados")
}

model ReaperturaEtapa {
  id                String          @id @default(uuid())
  expedienteId      String          @map("expediente_id")
  expedienteEtapaId String          @map("expediente_etapa_id")
  reopenedByUserId  String          @map("reopened_by_user_id")
  motivo            String          @db.Text
  estadoAnterior    EstadoEtapa     @map("estado_anterior")
  estadoNuevo       EstadoEtapa     @map("estado_nuevo")
  createdAt         DateTime        @default(now()) @map("created_at")
  expediente        Expediente      @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa   ExpedienteEtapa @relation(fields: [expedienteEtapaId], references: [id], onDelete: Cascade)
  reopenedBy        Usuario         @relation("ReaperturaUsuario", fields: [reopenedByUserId], references: [id])

  @@index([expedienteId, expedienteEtapaId])
  @@map("reaperturas_etapa")
}

model RecepcionExpediente {
  id                  String              @id @default(uuid())
  expedienteId        String              @unique @map("expediente_id")
  folioIngreso        String              @unique @map("folio_ingreso")
  estadoAdmisibilidad EstadoAdmisibilidad @map("estado_admisibilidad")
  createdByUserId     String?             @map("created_by_user_id")
  observaciones       String?             @db.Text
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  expediente          Expediente          @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  createdBy           Usuario?            @relation("RecepcionCreatedBy", fields: [createdByUserId], references: [id])

  @@map("recepciones_expediente")
}

model ChecklistTemplate {
  id          String                  @id @default(uuid())
  code        String                  @unique
  name        String
  descripcion String?                 @db.Text
  isActive    Boolean                 @default(true) @map("is_active")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  items       ChecklistTemplateItem[]
  checklists  Checklist[]

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id                  String                  @id @default(uuid())
  checklistTemplateId String                  @map("checklist_template_id")
  code                String
  categoria           String
  descripcion         String                  @db.Text
  isCritical          Boolean                 @default(false) @map("is_critical")
  isRequired          Boolean                 @default(true) @map("is_required")
  orderIndex          Int                     @map("order_index")
  createdAt           DateTime                @default(now()) @map("created_at")
  checklistTemplate   ChecklistTemplate       @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)
  resultados          ChecklistItemResultado[]

  @@unique([checklistTemplateId, code])
  @@index([checklistTemplateId, orderIndex])
  @@map("checklist_template_items")
}

model Checklist {
  id                  String                  @id @default(uuid())
  expedienteId        String                  @map("expediente_id")
  checklistTemplateId String                  @map("checklist_template_id")
  vigente             Boolean                 @default(true)
  estadoRegistro      EstadoRegistro          @default(VIGENTE) @map("estado_registro")
  progressPct         Int                     @default(0) @map("progress_pct")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  expediente          Expediente              @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  checklistTemplate   ChecklistTemplate       @relation(fields: [checklistTemplateId], references: [id])
  resultados          ChecklistItemResultado[]

  @@index([expedienteId])
  @@map("checklists")
}

model ChecklistItemResultado {
  id                      String                @id @default(uuid())
  checklistId             String                @map("checklist_id")
  checklistTemplateItemId String                @map("checklist_template_item_id")
  resultado               String
  observacion             String?               @db.Text
  isCriticalSnapshot      Boolean               @default(false) @map("is_critical_snapshot")
  isRequiredSnapshot      Boolean               @default(true) @map("is_required_snapshot")
  checkedByUserId         String?               @map("checked_by_user_id")
  checkedAt               DateTime?             @map("checked_at")
  createdAt               DateTime              @default(now()) @map("created_at")
  checklist               Checklist             @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistTemplateItem   ChecklistTemplateItem @relation(fields: [checklistTemplateItemId], references: [id])
  checkedBy               Usuario?              @relation("ChecklistItemResultadoUsuario", fields: [checkedByUserId], references: [id])

  @@unique([checklistId, checklistTemplateItemId])
  @@map("checklist_item_resultados")
}

model DeclaracionIncompatibilidad {
  id          String     @id @default(uuid())
  expedienteId String    @map("expediente_id")
  usuarioId   String     @map("usuario_id")
  scopeType   ScopeType  @map("scope_type")
  tipoEtapa   TipoEtapa? @map("tipo_etapa")
  firmada     Boolean    @default(false)
  firmadaAt   DateTime?  @map("firmada_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  expediente  Expediente @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  usuario     Usuario    @relation("DeclaracionUsuario", fields: [usuarioId], references: [id])

  @@unique([expedienteId, usuarioId, scopeType, tipoEtapa])
  @@map("declaraciones_incompatibilidad")
}
model RevisionTecnica {
  id                String            @id @default(uuid())
  expedienteId      String            @map("expediente_id")
  expedienteEtapaId String            @map("expediente_etapa_id")
  iteracion         Int
  resultado         ResultadoRevision
  estadoRegistro    EstadoRegistro    @map("estado_registro")
  observaciones     String?           @db.Text
  revisorId         String            @map("revisor_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  expediente        Expediente        @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa   ExpedienteEtapa   @relation(fields: [expedienteEtapaId], references: [id])
  revisor           Usuario           @relation("RevisionTecnicaRevisor", fields: [revisorId], references: [id])

  @@unique([expedienteId, iteracion])
  @@index([expedienteEtapaId])
  @@map("revisiones_tecnicas")
}

model RevisionLegal {
  id                String            @id @default(uuid())
  expedienteId      String            @map("expediente_id")
  expedienteEtapaId String            @map("expediente_etapa_id")
  iteracion         Int
  resultado         ResultadoRevision
  estadoRegistro    EstadoRegistro    @map("estado_registro")
  observaciones     String?           @db.Text
  revisorId         String            @map("revisor_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  expediente        Expediente        @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa   ExpedienteEtapa   @relation(fields: [expedienteEtapaId], references: [id])
  revisor           Usuario           @relation("RevisionLegalRevisor", fields: [revisorId], references: [id])

  @@unique([expedienteId, iteracion])
  @@index([expedienteEtapaId])
  @@map("revisiones_legales")
}

model ValidacionKml {
  id                String            @id @default(uuid())
  expedienteId      String            @map("expediente_id")
  expedienteEtapaId String            @map("expediente_etapa_id")
  iteracion         Int
  resultado         ResultadoRevision
  estadoRegistro    EstadoRegistro    @map("estado_registro")
  sistemaReferencia String?           @map("sistema_referencia")
  numeroPoligonos   Int?              @map("numero_poligonos")
  observaciones     String?           @db.Text
  revisorId         String            @map("revisor_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  expediente        Expediente        @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa   ExpedienteEtapa   @relation(fields: [expedienteEtapaId], references: [id])
  revisor           Usuario           @relation("ValidacionKmlRevisor", fields: [revisorId], references: [id])

  @@unique([expedienteId, iteracion])
  @@index([expedienteEtapaId])
  @@map("validaciones_kml")
}

model InformeTecnico {
  id                String                @id @default(uuid())
  expedienteId      String                @map("expediente_id")
  expedienteEtapaId String                @map("expediente_etapa_id")
  estado            EstadoInformeTecnico
  vigente           Boolean               @default(true)
  createdByUserId   String?               @map("created_by_user_id")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  expediente        Expediente            @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa   ExpedienteEtapa       @relation(fields: [expedienteEtapaId], references: [id])
  createdBy         Usuario?              @relation("InformeTecnicoCreatedBy", fields: [createdByUserId], references: [id])
  versiones         InformeTecnicoVersion[]

  @@index([expedienteId, vigente])
  @@map("informes_tecnicos")
}

model InformeTecnicoVersion {
  id                 String               @id @default(uuid())
  informeTecnicoId   String               @map("informe_tecnico_id")
  numeroVersion      Int                  @map("numero_version")
  contenido          Json?
  estadoRegistro     EstadoRegistro       @map("estado_registro")
  documentoVersionId String?              @map("documento_version_id")
  createdByUserId    String?              @map("created_by_user_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  informeTecnico     InformeTecnico       @relation(fields: [informeTecnicoId], references: [id], onDelete: Cascade)
  documentoVersion   DocumentoVersion?    @relation(fields: [documentoVersionId], references: [id])
  createdBy          Usuario?             @relation("InformeTecnicoVersionCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([informeTecnicoId, numeroVersion])
  @@map("informe_tecnico_versiones")
}

model ControlFinal {
  id                String             @id @default(uuid())
  expedienteId      String             @map("expediente_id")
  expedienteEtapaId String             @map("expediente_etapa_id")
  estado            EstadoControlFinal
  observaciones     String?            @db.Text
  aprobadorUserId   String?            @map("aprobador_user_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  expediente        Expediente         @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa   ExpedienteEtapa    @relation(fields: [expedienteEtapaId], references: [id])
  aprobador         Usuario?           @relation("ControlFinalAprobador", fields: [aprobadorUserId], references: [id])

  @@index([expedienteId])
  @@map("controles_finales")
}

model TipoDocumentoCatalogo {
  id          String      @id @default(uuid())
  code        String      @unique
  name        String
  descripcion String?     @db.Text
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  documentos  Documento[]

  @@map("tipos_documento_catalogo")
}

model Documento {
  id                      String                @id @default(uuid())
  expedienteId            String                @map("expediente_id")
  expedienteEtapaId       String?               @map("expediente_etapa_id")
  tipoDocumentoCatalogoId String                @map("tipo_documento_catalogo_id")
  estado                  EstadoDocumento       @default(ACTIVO)
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")
  deletedAt               DateTime?             @map("deleted_at")
  expediente              Expediente            @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  expedienteEtapa         ExpedienteEtapa?      @relation(fields: [expedienteEtapaId], references: [id])
  tipoDocumentoCatalogo   TipoDocumentoCatalogo @relation(fields: [tipoDocumentoCatalogoId], references: [id])
  versiones               DocumentoVersion[]

  @@index([expedienteId, expedienteEtapaId])
  @@map("documentos")
}

model DocumentoVersion {
  id                    String                 @id @default(uuid())
  documentoId           String                 @map("documento_id")
  numeroVersion         Int                    @map("numero_version")
  storageKey            String                 @unique @map("storage_key")
  nombreArchivoOriginal String                 @map("nombre_archivo_original")
  mimeType              String                 @map("mime_type")
  tamanoBytes           Int                    @map("tamano_bytes")
  hashArchivo           String?                @map("hash_archivo")
  estadoVersion         EstadoVersionDocumento @default(ACTIVA) @map("estado_version")
  uploadedByUserId      String                 @map("uploaded_by_user_id")
  uploadedAt            DateTime               @default(now()) @map("uploaded_at")
  documento             Documento              @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  uploadedBy            Usuario                @relation("DocumentoVersionUploadedBy", fields: [uploadedByUserId], references: [id])
  informeVersiones      InformeTecnicoVersion[]

  @@unique([documentoId, numeroVersion])
  @@map("documento_versiones")
}
model ReglaAlerta {
  id          String           @id @default(uuid())
  code        String           @unique
  name        String
  descripcion String?          @db.Text
  severity    SeveridadAlerta
  isActive    Boolean          @default(true) @map("is_active")
  config      Json?            @map("config")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  alertas     Alerta[]

  @@map("reglas_alerta")
}

model Alerta {
  id                String          @id @default(uuid())
  expedienteId      String          @map("expediente_id")
  reglaAlertaId     String?         @map("regla_alerta_id")
  scopeType         ScopeType       @map("scope_type")
  originType        OrigenAlerta    @map("origin_type")
  severity          SeveridadAlerta
  status            EstadoAlerta    @default(ACTIVA)
  blocking          Boolean         @default(false)
  title             String
  description       String          @db.Text
  idempotencyKey    String?         @map("idempotency_key")
  responsibleUserId String?         @map("responsible_user_id")
  resolvedByUserId  String?         @map("resolved_by_user_id")
  resolvedAt        DateTime?       @map("resolved_at")
  dueAt             DateTime?       @map("due_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  expediente        Expediente      @relation(fields: [expedienteId], references: [id], onDelete: Cascade)
  reglaAlerta       ReglaAlerta?    @relation(fields: [reglaAlertaId], references: [id])
  responsable       Usuario?        @relation("AlertaResponsable", fields: [responsibleUserId], references: [id])
  resolvedBy        Usuario?        @relation("AlertaResolvedBy", fields: [resolvedByUserId], references: [id])

  @@index([expedienteId, status, severity])
  @@index([idempotencyKey])
  @@map("alertas")
}

model NoConformidad {
  id                  String              @id @default(uuid())
  expedienteId        String?             @map("expediente_id")
  scopeType           ScopeType           @map("scope_type")
  severity            SeveridadNC
  status              EstadoNoConformidad @default(ABIERTA)
  codigo              String?             @unique
  titulo              String
  descripcion         String              @db.Text
  responsableUserId   String?             @map("responsable_user_id")
  fechaDeteccion      DateTime            @map("fecha_deteccion")
  fechaCompromiso     DateTime?           @map("fecha_compromiso")
  fechaCierre         DateTime?           @map("fecha_cierre")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  deletedAt           DateTime?           @map("deleted_at")
  expediente          Expediente?         @relation(fields: [expedienteId], references: [id])
  responsable         Usuario?            @relation("NoConformidadResponsable", fields: [responsableUserId], references: [id])
  accionesCorrectivas AccionCorrectiva[]

  @@index([expedienteId, status, severity])
  @@map("no_conformidades")
}

model AccionCorrectiva {
  id                String                 @id @default(uuid())
  noConformidadId   String                 @map("no_conformidad_id")
  responsableUserId String                 @map("responsable_user_id")
  estado            EstadoAccionCorrectiva
  descripcion       String                 @db.Text
  fechaCompromiso   DateTime               @map("fecha_compromiso")
  fechaCierre       DateTime?              @map("fecha_cierre")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  noConformidad     NoConformidad          @relation(fields: [noConformidadId], references: [id], onDelete: Cascade)
  responsable       Usuario                @relation("AccionCorrectivaResponsable", fields: [responsableUserId], references: [id])

  @@index([noConformidadId, estado])
  @@map("acciones_correctivas")
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String?     @map("user_id")
  expedienteId  String?     @map("expediente_id")
  entityType    String      @map("entity_type")
  entityId      String      @map("entity_id")
  accion        String
  valorAnterior Json?       @map("valor_anterior")
  valorNuevo    Json?       @map("valor_nuevo")
  comentario    String?     @db.Text
  ipAddress     String?     @map("ip_address")
  createdAt     DateTime    @default(now()) @map("created_at")
  usuario       Usuario?    @relation("AuditLogUsuario", fields: [userId], references: [id])
  expediente    Expediente? @relation(fields: [expedienteId], references: [id])

  @@index([expedienteId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ReportJob {
  id                String          @id @default(uuid())
  requestedByUserId String          @map("requested_by_user_id")
  type              String
  status            EstadoReportJob @default(PENDIENTE)
  params            Json?           @map("params")
  result            Json?           @map("result")
  errorMessage      String?         @db.Text @map("error_message")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  requestedBy       Usuario         @relation("ReportJobSolicitante", fields: [requestedByUserId], references: [id])

  @@index([requestedByUserId, status])
  @@map("report_jobs")
}

model CatalogoParametro {
  id          String   @id @default(uuid())
  tipo        String
  code        String
  name        String
  descripcion String?  @db.Text
  sortOrder   Int?     @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json?    @map("metadata")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([tipo, code])
  @@index([tipo, isActive])
  @@map("catalogos_parametro")
}
