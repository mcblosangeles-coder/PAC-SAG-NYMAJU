# Local development
NODE_ENV=development

# API
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false
TRUSTED_PROXY_CIDRS=
QA_INTERNAL_HOSTNAMES=
QA_INTERNAL_PATH_PREFIX=/api/v1/internal/qa
TRAFFIC_PROFILE_REJECT_ON_MISSING_HEADER=
TRAFFIC_PROFILE_REJECT_ON_INVALID_HEADER=
METRICS_TOKEN=
METRICS_COLLECTOR_ENABLED=true
METRICS_COLLECTOR_INTERVAL_SECONDS=60
METRICS_RETENTION_DAYS=30
ALERTS_EVALUATOR_ENABLED=true
ALERTS_EVALUATOR_INTERVAL_SECONDS=300
ALERTS_NOTIFICATION_COOLDOWN_SECONDS=900
ALERTS_NOTIFY_CHANNELS=log,audit
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORE=redis
RATE_LIMIT_REQUIRE_REDIS=false
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN_MAX=10
RATE_LIMIT_AUTH_REFRESH_MAX=20
RATE_LIMIT_INTERNAL_MAX=120

# Database
DATABASE_URL=postgresql://pac_user:pac_password@localhost:5432/pac_nymaju_spr?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth (placeholder for Block C)
JWT_ACCESS_SECRET=replace_in_local_env
JWT_REFRESH_SECRET=replace_in_local_env

# Logging (M3-D2)
# Optional override: debug|info|warn|error
LOG_LEVEL_MIN=
# Optional override: true|false
LOG_HTTP_REQUEST_STARTED=
# Optional override: sample rate 0..1 for http.request.started/completed
LOG_HTTP_SAMPLE_RATE=
# Optional override: comma-separated wildcard patterns to exclude from request logs
# Example: /api/v1/health,/api/v1/polling/*
LOG_EXCLUDE_PATH_PATTERNS=
# Optional override: comma-separated pattern=rate entries
# Example: /api/v1/health=0,/api/v1/expedientes/*=0.2
LOG_HTTP_PATH_SAMPLE_RULES=

# Seed admin user (optional override)
SEED_ADMIN_EMAIL=admin@pac.local
SEED_ADMIN_PASSWORD=ChangeMe_123!
SEED_ADMIN_ROLE=admin_sistema
